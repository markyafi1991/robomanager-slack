# Copy this to ~/.config/robomanager/env and fill it in (chmod 600). Never commit real values.

# --- Required ---
SLACK_BOT_TOKEN=xoxb-...        # Slack app -> OAuth & Permissions -> Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...        # Slack app -> Socket Mode -> App-Level Token (connections:write)
ROBOMANAGER_KNOWLEDGE_PATH=/path/to/your/notes   # a folder of Markdown notes (e.g. an Obsidian vault)

# --- Auth (optional) ---
# If unset, the Claude Agent SDK uses your existing Claude Code login.
# Set a key to bill the Anthropic API instead (get one at console.anthropic.com).
ANTHROPIC_API_KEY=

# --- Write guardrails (append-only) ---
# Top-level folders the bot may APPEND to (comma-separated). Leave blank for fully read-only.
ROBOMANAGER_WRITE_ALLOW=Logs,Inbox
# Top-level folders the bot must NEVER read or write (your privacy wall, comma-separated).
ROBOMANAGER_PRIVATE_DIRS=Personal,Private

# --- Optional ClickUp integration ---
CLICKUP_API_KEY=
CLICKUP_TEAM_ID=

# --- Nudges & misc ---
ROBOMANAGER_CHANNEL=           # Slack channel ID for proactive nudges; blank = off
ROBOMANAGER_MODEL=claude-sonnet-4-6
ROBOMANAGER_TZ=America/Chicago
ROBOMANAGER_PERSONA=a personal operations manager
